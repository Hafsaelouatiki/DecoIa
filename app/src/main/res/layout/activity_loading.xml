<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/warm_white"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:indeterminateTint="@color/terracotta" />

    <TextView
        android:id="@+id/tvLoadingStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:text="Transformation en cours..."
        android:textColor="@color/espresso"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/step1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ Analyse de la pièce"
            android:textColor="@color/espresso"
            android:alpha="0.5"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/step2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="○ Génération du nouveau design"
            android:textColor="@color/espresso"
            android:alpha="0.5"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/step3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="○ Recherche du mobilier"
            android:textColor="@color/espresso"
            android:alpha="0.5"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/step4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="○ Préparation du résultat"
            android:textColor="@color/espresso"
            android:alpha="0.5"
            android:textSize="16sp" />

    </LinearLayout>
</LinearLayout>