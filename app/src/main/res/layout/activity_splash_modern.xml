<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/luxury_off_white"
    android:gravity="center">

    <ImageView
        android:id="@+id/ivSplashLogo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_centerHorizontal="true"
        android:src="@android:drawable/ic_menu_gallery"
        android:tint="@color/luxury_brown_light" />

    <TextView
        android:id="@+id/tvSplashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/ivSplashLogo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:text="DecoIA"
        android:textColor="@color/luxury_espresso"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="serif" />

</RelativeLayout>