<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/luxury_off_white">

    <ImageView
        android:id="@+id/ivIllustration"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_alignParentTop="true"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        android:alpha="0.8" />

    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_alignBottom="@id/ivIllustration"
        android:background="@drawable/gradient_fade" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/ivIllustration"
        android:layout_marginTop="-40dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DecoIA"
            android:textColor="@color/luxury_espresso"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Transformez votre intérieur avec l’intelligence artificielle"
            android:textColor="@color/luxury_brown_light"
            android:textSize="18sp"
            android:lineSpacingExtra="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            style="@style/LuxuryButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="48dp"
            android:text="Se connecter"
            android:textAllCaps="false"
            android:textSize="18sp"
            app:cornerRadius="30dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:text="Créer un compte"
            android:textAllCaps="false"
            android:textColor="@color/luxury_espresso"
            android:textSize="18sp"
            app:cornerRadius="30dp"
            app:strokeColor="@color/luxury_espresso" />

    </LinearLayout>

</RelativeLayout>