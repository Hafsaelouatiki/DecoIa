<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.DecoIA" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/luxury_brown_light</item>
        <item name="android:statusBarColor">@color/luxury_off_white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.DecoIA" parent="Base.Theme.DecoIA" />

    <style name="LuxuryButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/luxury_brown_light</item>
        <item name="android:textColor">@color/white</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Luxury</item>
    </style>

    <style name="ShapeAppearance.Luxury" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">24dp</item>
        <item name="cornerFamily">rounded</item>
    </style>

    <style name="LuxuryInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/luxury_brown_light</item>
        <item name="hintTextColor">@color/luxury_brown_light</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
    </style>

</resources>